# Google AI Studio API key — required
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# --- Optional overrides (defaults shown) ---

# Gemini model for video analysis and script fitting
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash

# Gemini model for TTS synthesis
GEMINI_MODEL_TTS=gemini-2.5-flash-preview-tts

# TTS voice name
GEMINI_TTS_VOICE=Kore

# Silence detection threshold in dB (negative value)
SILENCE_NOISE_DB=-35

# Minimum silence duration to consider as a gap (seconds)
SILENCE_MIN_DURATION=1.5

# Safety margin on each side of a gap (milliseconds)
SILENCE_MARGIN_MS=200

# Audio description speech rate (words per minute, ADLAB standard)
AD_WORDS_PER_MINUTE=160

# Maximum number of AD segments per project
AD_MAX_SEGMENTS=200

# Temporary files directory
TEMP_DIR=temp
